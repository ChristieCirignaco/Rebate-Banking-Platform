# Copy to .env and fill in values. This file is the TEMPLATE and is committed — it must never
# hold a real secret. Real values live in .env locally (gitignored) and in the host's
# environment variables in production (Vercel → Settings → Environment Variables).

# ----- Database -----
# LOCAL (Docker, `pnpm db:up`): pooled and direct are the same connection.
DATABASE_URL="postgresql://rebate:rebate@localhost:5544/rebate?schema=public"
DIRECT_URL="postgresql://rebate:rebate@localhost:5544/rebate?schema=public"
#
# PRODUCTION (Neon) — set these two in the host's env vars, NOT here. Neon gives one endpoint
# id (e.g. ep-name-1234); the POOLED host is the same id with "-pooler" inserted before the
# region. Both are required and they are not interchangeable:
#   DATABASE_URL → pooled (pgbouncer). The app opens a connection per request; serverless
#                  would exhaust Neon's direct limit without the pooler.
#   DIRECT_URL   → direct. Prisma Migrate needs a real session (pgbouncer can't run DDL),
#                  which is why schema.prisma declares directUrl separately.
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# ----- File storage -----
# UNSET (local): uploads go to ./storage on disk, served via our access-controlled routes.
# SET (production): lib/storage switches to Vercel Blob automatically. Required on Vercel —
# its filesystem is ephemeral and read-only outside /tmp, so disk writes fail or vanish and
# KYC documents / deposit proofs / avatars would break. Vercel injects this when a Blob store
# is linked to the project (Storage → Blob → Connect); don't set it by hand.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
#
# Optional: override the local storage directory (ignored when Blob is on).
# STORAGE_DIR="/absolute/path/to/storage"

# ----- App -----
NODE_ENV="development"

# ----- Better Auth -----
# Generate a strong secret: openssl rand -base64 33
# NOTE: this also keys the payment-credentials cipher and the KYC/ticket attachment tokens
# (lib/crypto/secrets, lib/kyc/attachment-token) unless PAYMENT_CREDENTIALS_KEY is set —
# rotating it invalidates stored gateway secrets and every issued attachment token.
BETTER_AUTH_SECRET="replace-with-a-32+-char-random-secret"
BETTER_AUTH_URL="http://localhost:3000"
# Production: BETTER_AUTH_URL must be the real origin, e.g. "https://yourdomain.com"

# ----- Email (Resend) -----
# When unset, emails are logged to the server console (dev). Set to send for real — every
# transaction notification and admin alert goes out through this.
RESEND_API_KEY=""
# Optional From override; else the General-settings From name/email is used.
# RESEND_FROM="Rebate Bank <no-reply@yourdomain.com>"

# ----- Admin bootstrap (pnpm db:seed) -----
ADMIN_EMAIL="admin@rebate.local"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Admin"
