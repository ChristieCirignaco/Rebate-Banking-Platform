// Prisma schema — Rebate Banking
//
// Postgres via the default engine over DATABASE_URL (Docker locally, Neon in prod).
// Better Auth owns user/session/account/verification; ids are UUIDs (Better Auth is
// configured to generate them). Money is stored as integer minor units (bigint), the
// ledger is append-only, and wallet balances are a materialized cache kept in sync by
// a single-statement CTE (design spec §5, §7).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Identity (Better Auth) + app profile/admin fields. Added columns are nullable
// or defaulted so Better Auth's inserts (which only set its own fields) succeed.
// ---------------------------------------------------------------------------

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String?   @default("user") // user | admin | super_admin
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?

  // App profile
  username        String?   @unique
  phone           String?
  country         String?
  timezone        String?
  locale          String?
  currency        String    @default("USD")
  gender          String    @default("unspecified") // male | female | other | unspecified
  birthday        DateTime?
  address         String?
  // App admin state
  status            String   @default("active") // active | suspended | pending
  kycStatus         String   @default("not_submitted") // approved | pending | not_submitted | rejected
  kycDocumentType   String? // e.g. Passport | National ID | Driver's License (free-form label)
  lastLoginAt       DateTime?
  activationCode    String?
  twoFactorEnabled  Boolean?  @default(false) // Better Auth twoFactor plugin (TOTP)
  withdrawalStatus  String   @default("allowed") // allowed | pending | hold | suspended | restricted
  withdrawalMessage String?
  controls          Json? // per-user capability toggles (design spec §9.3 / user controls)
  transferCodes     Json? // { imf: string[], tax: string[], cot: string[] }

  // Referrals (self relation)
  referredById String?
  referredBy   User?   @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals    User[]  @relation("Referrals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions      Session[]
  accounts      Account[]
  wallets       Wallet[]
  transactions  WalletTransaction[]
  notifications  Notification[]
  products       Product[]
  deposits       Deposit[]
  withdrawals    Withdraw[]
  sentTransfers     Transfer[] @relation("SentTransfers")
  receivedTransfers Transfer[] @relation("ReceivedTransfers")
  kycSubmissions KycSubmission[]
  tickets        Ticket[]
  createdActivationCodes ActivationCode[] @relation("ActivationCodeCreatedBy")
  twoFactor      TwoFactor?
  loginOtps      LoginOtp[]

  @@index([status])
  @@index([kycStatus])
  @@index([createdAt])
  @@map("user")
}

model Session {
  id             String   @id
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  loginOtp LoginOtp?

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  password              String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// Better Auth twoFactor plugin. TOTP secret + backup codes are stored ENCRYPTED (AES via
// BETTER_AUTH_SECRET) and never returned to the client. Camelcase columns match the other
// Better-Auth-owned tables (user/session/account); ids come from the app's generateId hook.
model TwoFactor {
  id                      String    @id
  userId                  String    @unique
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret                  String // encrypted TOTP secret
  backupCodes             String // encrypted JSON of one-time backup codes
  verified                Boolean?  @default(true) // false until the first TOTP confirm
  failedVerificationCount Int?      @default(0) // account-lockout counter
  lockedUntil             DateTime?

  @@map("two_factor")
}

// App-owned "email OTP on login" challenge: when the admin enables it, every regular-user
// session gets a one-time email code that must be entered before the dashboard unlocks. The
// code is stored HASHED (HMAC-SHA256) and is single-use, expiring, and attempt-limited.
// One pending row per session; deleted on success or when the session is revoked.
// Email "OTP on login" challenge, one row per session while the gate is on. The row is
// created lazily when the user reaches /verify-otp (so the session always exists — no race
// with Better Auth's 2FA throwaway session), and kept after success as a per-session
// "verified" marker: the gate is fail-closed, so a session with no verifiedAt is blocked.
model LoginOtp {
  id         String    @id @default(uuid())
  sessionId  String    @unique @map("session_id")
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String    @map("code_hash")
  attempts   Int       @default(0) // wrong guesses against the CURRENT code
  sends      Int       @default(0) // codes issued this session (durable brute-force cap)
  expiresAt  DateTime  @map("expires_at")
  lastSentAt DateTime? @map("last_sent_at") // server-side resend cooldown
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("login_otps")
}

// ---------------------------------------------------------------------------
// Wallet & ledger. Balance is a cache of the append-only ledger; currency
// integrity is enforced by the composite FK on wallet_transactions.
// ---------------------------------------------------------------------------

model Wallet {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency     String
  balanceMinor BigInt   @default(0) @map("balance_minor")
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  transactions WalletTransaction[]

  @@unique([userId, currency])
  @@unique([id, currency]) // backs the composite FK below
  @@index([userId])
  @@map("wallets")
}

model WalletTransaction {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletId          String   @map("wallet_id")
  currency          String
  wallet            Wallet   @relation(fields: [walletId, currency], references: [id, currency], onDelete: Cascade)
  direction         String // credit | debit
  amountMinor       BigInt   @map("amount_minor")
  source            String // deposit | withdrawal | withdrawal_reversal | adjustment | fee | transfer | rebate | reward
  referenceType     String?  @map("reference_type")
  referenceId       String?  @map("reference_id")
  idempotencyKey    String   @unique @map("idempotency_key")
  balanceAfterMinor BigInt   @map("balance_after_minor")
  status            String   @default("completed") // completed | pending | failed
  provider          String?
  description       String?
  memo              String?
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([walletId])
  @@index([createdAt]) // site-wide /admin/transaction ledger sorts across all users
  @@map("wallet_transactions")
}

// ---------------------------------------------------------------------------
// Currency configuration. The admin manages every supported currency (fiat or
// crypto): display metadata, a manual "1 USD = rate" conversion rate, an auto-wallet
// flag, default/active toggles, and per-role fee + limit config. `code` matches the
// free String currency on wallets/transactions (kept without a hard FK so existing
// wallet rows are never orphaned). Rates/fees/limits are config thresholds, so Decimal
// — ledger money stays BigInt minor units.
// ---------------------------------------------------------------------------

model Currency {
  id         String         @id @default(uuid())
  code       String         @unique
  name       String
  symbol     String
  type       String         @default("fiat") // fiat | crypto
  flagUrl    String?        @map("flag_url")
  rate       Decimal        @default(1) @map("rate") @db.Decimal(38, 18)
  autoWallet Boolean        @default(false) @map("auto_wallet")
  isDefault  Boolean        @default(false) @map("is_default")
  isActive   Boolean        @default(true) @map("is_active")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  roles      CurrencyRole[]
  depositMethods DepositMethod[]
  withdrawMethods WithdrawMethod[]

  @@index([type])
  @@map("currencies")
}

model CurrencyRole {
  id         String   @id @default(uuid())
  currencyId String   @map("currency_id")
  currency   Currency @relation(fields: [currencyId], references: [id], onDelete: Cascade)
  role       String // sender | voucher | payment | withdraw
  feeType    String   @default("percent") @map("fee_type") // percent | fixed
  feeValue   Decimal  @default(0) @map("fee_value") @db.Decimal(38, 18)
  minAmount  Decimal  @default(0) @map("min_amount") @db.Decimal(38, 18)
  maxAmount  Decimal  @default(0) @map("max_amount") @db.Decimal(38, 18)
  enabled    Boolean  @default(true)

  @@unique([currencyId, role])
  @@index([currencyId])
  @@map("currency_roles")
}

// ---------------------------------------------------------------------------
// Automatic payment gateways. Metadata is public; credential values (keys/secrets)
// live in `credentials` as a single AES-256-GCM-encrypted JSON blob and are never
// returned to the client in the clear. The webhook/IPN URL is derived from the app
// URL at read time, not stored.
// ---------------------------------------------------------------------------

model PaymentGateway {
  id                  String   @id @default(uuid())
  slug                String   @unique
  name                String
  logo                String?
  supportedCurrencies String[] @map("supported_currencies")
  withdrawAvailable   Boolean  @default(false) @map("withdraw_available")
  isActive            Boolean  @default(false) @map("is_active")
  credentials         String?  @map("credentials") // AES-256-GCM encrypted JSON of the gateway's fields
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  depositMethods      DepositMethod[]
  withdrawMethods     WithdrawMethod[]

  @@map("payment_gateways")
}

// ---------------------------------------------------------------------------
// Deposits. Design decisions:
//  - DepositMethod is the ONE config table for both automatic and manual methods
//    (`type`), so it reuses the shared models instead of duplicating them: an auto
//    method references an existing PaymentGateway (paymentGatewayId, nullable — used
//    only for auto; credentials stay on the gateway, never copied here) and an existing
//    Currency (currencyId). A manual method references only a Currency and owns a set of
//    ManualMethodField rows (the dynamic form a user fills at deposit time).
//  - Deposit is the order/request lifecycle (mutable status), separate from the
//    append-only wallet_transactions ledger. Approving a deposit posts an immutable
//    ledger credit via postLedgerEntry (idempotency key deposit:<id>) and links it here.
//    "Manual Requests" = manual deposits still pending; "Deposit History" = all deposits.
//    History rows are deletable (admin housekeeping) without touching the ledger.
// ---------------------------------------------------------------------------

model DepositMethod {
  id               String              @id @default(uuid())
  type             String // auto | manual
  name             String
  symbol           String
  methodCode       String?             @map("method_code") // slug, manual methods
  logo             String?
  currencyId       String              @map("currency_id")
  currency         Currency            @relation(fields: [currencyId], references: [id], onDelete: Restrict)
  paymentGatewayId String?             @map("payment_gateway_id") // auto only
  paymentGateway   PaymentGateway?     @relation(fields: [paymentGatewayId], references: [id], onDelete: SetNull)
  rate             Decimal             @default(1) @db.Decimal(38, 18)
  chargeType       String              @default("percent") @map("charge_type") // percent | fixed
  chargeValue      Decimal             @default(0) @map("charge_value") @db.Decimal(38, 18)
  minAmount        Decimal             @default(0) @map("min_amount") @db.Decimal(38, 18)
  maxAmount        Decimal             @default(0) @map("max_amount") @db.Decimal(38, 18)
  instructions     String? // manual: rich-text (HTML) shown to the user
  isActive         Boolean             @default(true) @map("is_active")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  fields           ManualMethodField[]
  deposits         Deposit[]

  @@index([type])
  @@index([currencyId])
  @@index([paymentGatewayId])
  @@map("deposit_methods")
}

model ManualMethodField {
  id              String        @id @default(uuid())
  depositMethodId String        @map("deposit_method_id")
  method          DepositMethod @relation(fields: [depositMethodId], references: [id], onDelete: Cascade)
  label           String
  type            String        @default("input") // input | textarea | file
  required        Boolean       @default(true)
  sortOrder       Int           @default(0) @map("sort_order")

  @@index([depositMethodId])
  @@map("manual_method_fields")
}

model Deposit {
  id                  String         @id @default(uuid())
  txnId               String         @unique @map("txn_id") // human reference, e.g. DEP-XXXXXX
  userId              String         @map("user_id")
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  depositMethodId     String?        @map("deposit_method_id")
  method              DepositMethod? @relation(fields: [depositMethodId], references: [id], onDelete: SetNull)
  type                String // auto | manual (denormalized from the method)
  currency            String // ISO code (denormalized so the ledger credit is exact)
  amountMinor         BigInt         @map("amount_minor")
  feeMinor            BigInt         @default(0) @map("fee_minor")
  status              String         @default("pending") // pending | completed | canceled | failed
  provider            String? // gateway/method name shown in history
  description         String?
  fieldValues         Json?          @map("field_values") // manual: the custom-field values the user submitted
  remarks             String? // admin remarks on review
  reviewedById        String?        @map("reviewed_by_id")
  reviewedByName      String?        @map("reviewed_by_name") // snapshot; survives the reviewer being renamed/deleted
  reviewedAt          DateTime?      @map("reviewed_at")
  walletTransactionId String?        @map("wallet_transaction_id") // ledger entry created on approval
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  @@index([status])
  @@index([type, status])
  @@index([userId])
  @@index([depositMethodId])
  @@index([createdAt])
  @@map("deposits")
}

// ---------------------------------------------------------------------------
// Withdrawals. Mirrors the Deposit design (shared PaymentGateway + Currency, no
// duplicated credentials/ledger) with the money direction reversed and two extras:
//  - Manual methods carry a Process Time (value + unit) instead of rich-text instructions.
//  - A weekly WithdrawScheduleDay table drives auto-processing days.
// Money model (held funds): a withdrawal REQUEST debits the wallet (source "withdrawal",
// linked as heldTransactionId). Approve just completes it; Reject REFUNDS via a
// "withdrawal_reversal" credit (refundTransactionId). Both ledger writes are idempotent.
// ---------------------------------------------------------------------------

model WithdrawMethod {
  id               String                @id @default(uuid())
  type             String // auto | manual
  name             String
  symbol           String
  methodCode       String?               @map("method_code")
  logo             String?
  currencyId       String                @map("currency_id")
  currency         Currency              @relation(fields: [currencyId], references: [id], onDelete: Restrict)
  paymentGatewayId String?               @map("payment_gateway_id")
  paymentGateway   PaymentGateway?       @relation(fields: [paymentGatewayId], references: [id], onDelete: SetNull)
  rate             Decimal               @default(1) @db.Decimal(38, 18)
  chargeType       String                @default("percent") @map("charge_type") // percent | fixed
  chargeValue      Decimal               @default(0) @map("charge_value") @db.Decimal(38, 18)
  minAmount        Decimal               @default(0) @map("min_amount") @db.Decimal(38, 18)
  maxAmount        Decimal               @default(0) @map("max_amount") @db.Decimal(38, 18)
  processTimeValue Int?                  @map("process_time_value") // manual: value
  processTimeUnit  String?               @map("process_time_unit") // manual: minute | hour | day
  isActive         Boolean               @default(true) @map("is_active")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  fields           WithdrawMethodField[]
  withdrawals      Withdraw[]

  @@index([type])
  @@index([currencyId])
  @@index([paymentGatewayId])
  @@map("withdraw_methods")
}

model WithdrawMethodField {
  id               String         @id @default(uuid())
  withdrawMethodId String         @map("withdraw_method_id")
  method           WithdrawMethod @relation(fields: [withdrawMethodId], references: [id], onDelete: Cascade)
  label            String
  type             String         @default("input") // input | textarea | file
  required         Boolean        @default(true)
  sortOrder        Int            @default(0) @map("sort_order")

  @@index([withdrawMethodId])
  @@map("withdraw_method_fields")
}

model Withdraw {
  id                  String          @id @default(uuid())
  txnId               String          @unique @map("txn_id")
  userId              String          @map("user_id")
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawMethodId    String?         @map("withdraw_method_id")
  method              WithdrawMethod? @relation(fields: [withdrawMethodId], references: [id], onDelete: SetNull)
  type                String // auto | manual
  currency            String // ISO code (denormalized)
  amountMinor         BigInt          @map("amount_minor")
  feeMinor            BigInt          @default(0) @map("fee_minor")
  status              String          @default("pending") // pending | completed | canceled | failed
  provider            String?
  description         String?
  fieldValues         Json?           @map("field_values")
  remarks             String?
  reviewedById        String?         @map("reviewed_by_id")
  reviewedByName      String?         @map("reviewed_by_name") // snapshot; survives the reviewer being renamed/deleted
  reviewedAt          DateTime?       @map("reviewed_at")
  heldTransactionId   String?         @map("held_transaction_id") // the "withdrawal" debit that held the funds
  refundTransactionId String?         @map("refund_transaction_id") // the "withdrawal_reversal" credit on reject
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  @@index([status])
  @@index([type, status])
  @@index([userId])
  @@index([withdrawMethodId])
  @@index([createdAt])
  @@map("withdraws")
}

model WithdrawScheduleDay {
  day       Int      @id // 0 = Sunday … 6 = Saturday
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("withdraw_schedule_days")
}

// ---------------------------------------------------------------------------
// Transfers. Three kinds via `type`:
//  - internal: user → user on-platform. Approval credits the recipient's wallet.
//  - domestic / wire: user → external bank. Approval just completes (funds left the
//    platform); wire additionally requires the sender to clear the IMF→TAX→COT code gate
//    (User.transferCodes) before the request is created.
// All three DEBIT the sender on request (held) and, like withdrawals, refund on reject via a
// "transfer_reversal" credit. Money model mirrors Withdraw (heldTransactionId / refund) with
// an extra creditTransactionId for the internal recipient credit.
// ---------------------------------------------------------------------------

model Transfer {
  id       String @id @default(uuid())
  txnId    String @unique @map("txn_id") // human reference, e.g. TRF-XXXXXX
  userId   String @map("user_id") // sender
  user     User   @relation("SentTransfers", fields: [userId], references: [id], onDelete: Cascade)
  type     String // internal | domestic | wire
  currency String // ISO code (denormalized)

  amountMinor BigInt @map("amount_minor")
  feeMinor    BigInt @default(0) @map("fee_minor")
  status      String @default("pending") // pending | completed | rejected | canceled | failed

  // Recipient — internal points at a real user; domestic/wire capture external bank details.
  recipientUserId  String? @map("recipient_user_id")
  recipientUser    User?   @relation("ReceivedTransfers", fields: [recipientUserId], references: [id], onDelete: SetNull)
  recipientName    String? @map("recipient_name") // display snapshot / account holder name
  recipientDetails Json?   @map("recipient_details") // domestic/wire: { bankName, accountNumber, routingNumber?, swift?, iban?, country?, ... }

  codesVerified Boolean @default(false) @map("codes_verified") // wire: IMF→TAX→COT cleared

  // Ledger links (see money model above).
  debitTransactionId  String? @map("debit_transaction_id") // sender hold on request
  creditTransactionId String? @map("credit_transaction_id") // recipient credit (internal, on approve)
  refundTransactionId String? @map("refund_transaction_id") // sender refund (on reject)

  description    String?
  remarks        String? // admin remarks on review
  reviewedById   String?   @map("reviewed_by_id")
  reviewedByName String?   @map("reviewed_by_name") // snapshot; survives the reviewer being renamed/deleted
  reviewedAt     DateTime? @map("reviewed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([type, status])
  @@index([userId])
  @@index([recipientUserId])
  @@index([createdAt])
  @@map("transfers")
}

// ---------------------------------------------------------------------------
// App support models
// ---------------------------------------------------------------------------

model Notification {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // user notices: email | push — admin alerts: kyc_submitted | deposit_requested | withdraw_requested
  title       String?
  message     String
  scheduledAt DateTime?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  // Backs the admin feed query: where {userId, type in ALERT_TYPES} ordered by createdAt.
  @@index([userId, type, createdAt])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Rebate product submissions. Users submit a purchased product for review; an
// admin approves/rejects, and approval is what later credits the wallet. Price is
// stored as integer minor units (like wallets) so no float ever touches money.
// ---------------------------------------------------------------------------

model Product {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  priceMinor BigInt    @map("price_minor")
  currency   String    @default("USD")
  quantity   Int       @default(1)
  imageUrl   String?   @map("image_url")
  status     String    @default("pending") // pending | approved | rejected
  adminNote  String?   @map("admin_note")
  reviewedAt DateTime? @map("reviewed_at")
  reviewedBy String?   @map("reviewed_by") // reviewing admin's user id
  reviewedByName String? @map("reviewed_by_name") // snapshot; survives the reviewer being renamed/deleted
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("products")
}

model ActivationCode {
  id        String   @id @default(uuid())
  code      String   @unique
  type      String   @default("admin_created") // admin_created | user_entered
  status    String   @default("active") // active | suspended
  notes     String?
  createdBy String? // admin's user id; null once the admin is deleted, or for a system/user-entered code
  createdByAdmin User? @relation("ActivationCodeCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  createdByName  String? @map("created_by_name") // snapshot; survives the admin being renamed/deleted
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([type])
  @@index([createdBy])
  @@index([createdAt])
  @@map("activation_codes")
}

/// Feature flags toggled from the admin panel. Fail closed when a key is missing.
model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  description String?
  updatedBy   String?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

/// Admin-managed site settings, one JSON row per group (general | branding | plugins |
/// security | limits | legal). The shape of each group's `value` is typed in
/// lib/settings; secret fields (API keys/tokens) are stored encrypted inside the JSON.
/// Adding a field to a group needs no migration — only a defaults/type update.
model SiteSetting {
  key       String   @id // the group id
  value     Json // the group's settings object (secret sub-fields stored encrypted)
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ---------------------------------------------------------------------------
// KYC: an admin-defined verification template (a set of dynamic fields) that
// users submit against. A submission snapshots the template title + field values
// (text/number inline, file fields hold a storage key) for review. Mirrors the
// DepositMethod + ManualMethodField + Deposit trio. Users only (no merchants).
// ---------------------------------------------------------------------------

model KycTemplate {
  id           String             @id @default(uuid())
  title        String
  description  String?
  applicableTo String             @default("user") @map("applicable_to") // user (merchants unsupported)
  status       String             @default("active") // active | inactive
  fields       KycTemplateField[]
  submissions  KycSubmission[]
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@map("kyc_templates")
}

model KycTemplateField {
  id         String      @id @default(uuid())
  templateId String      @map("template_id")
  template   KycTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label      String
  type       String      @default("text") // text | file | number
  required   Boolean     @default(true)
  sortOrder  Int         @default(0) @map("sort_order")

  @@index([templateId])
  @@map("kyc_template_fields")
}

model KycSubmission {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId    String?      @map("template_id")
  template      KycTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateTitle String?      @map("template_title") // snapshot; survives template rename/delete
  status        String       @default("pending") // pending | approved | rejected
  fieldValues   Json?        @map("field_values") // [{ label, type, value, name?, contentType? }]
  note          String? // optional note the user submitted with the request
  remarks       String? // admin remarks recorded on review
  manual        Boolean      @default(false) // admin-created/manually-approved (no user submission)
  reviewedById  String?      @map("reviewed_by_id")
  reviewedByName String?     @map("reviewed_by_name") // snapshot; survives the reviewer being renamed/deleted
  reviewedAt    DateTime?    @map("reviewed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([templateId])
  @@index([createdAt])
  @@map("kyc_submissions")
}

// ---------------------------------------------------------------------------
// Support tickets. A user opens a ticket (subject + body); staff reply in a
// threaded conversation and move it through open -> pending/replied -> closed.
// Category is a lightweight lookup owned by the separate Support Category
// section — referenced here, not duplicated. A denormalized name snapshot
// keeps ticket history readable if a category is later renamed or removed.
// ---------------------------------------------------------------------------

model SupportCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tickets Ticket[]

  @@map("support_categories")
}

model Ticket {
  id            String           @id @default(uuid())
  ticketCode    String           @unique @map("ticket_code") // human reference, e.g. HQ0HN1H (shown as #HQ0HN1H)
  userId        String           @map("user_id")
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId    String?          @map("category_id")
  category      SupportCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryName  String?          @map("category_name") // snapshot; survives category rename/delete
  subject       String
  body          String
  priority      String           @default("medium") // low | medium | high | urgent
  status        String           @default("open") // open | pending | replied | closed
  lastRepliedAt DateTime?        @map("last_replied_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  messages TicketMessage[]

  @@index([status])
  @@index([userId])
  @@index([categoryId])
  @@index([createdAt])
  @@map("tickets")
}

model TicketMessage {
  id          String   @id @default(uuid())
  ticketId    String   @map("ticket_id")
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderType  String   @map("sender_type") // user | admin
  senderId    String   @map("sender_id") // the ticket's user, or the replying admin
  senderName  String   @map("sender_name") // snapshot for display without an extra join
  body        String
  attachments Json? // [{ name, key, url, contentType, size }]
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([ticketId])
  @@map("ticket_messages")
}
