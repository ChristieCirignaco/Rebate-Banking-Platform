// Prisma schema — Rebate Banking
//
// Postgres via the default engine over DATABASE_URL (Docker locally, Neon in prod).
// Better Auth owns user/session/account/verification; ids are UUIDs (Better Auth is
// configured to generate them). Money is stored as integer minor units (bigint), the
// ledger is append-only, and wallet balances are a materialized cache kept in sync by
// a single-statement CTE (design spec §5, §7).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Identity (Better Auth) + app profile/admin fields. Added columns are nullable
// or defaulted so Better Auth's inserts (which only set its own fields) succeed.
// ---------------------------------------------------------------------------

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String?   @default("user")
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?

  // App profile
  username        String?   @unique
  phone           String?
  country         String?
  timezone        String?
  locale          String?
  currency        String    @default("USD")
  gender          String    @default("unspecified")
  birthday        DateTime?
  address         String?
  // App admin state
  status            String   @default("active") // active | suspended | pending
  kycStatus         String   @default("not_submitted") // approved | pending | not_submitted | rejected
  kycDocumentType   String?
  lastLoginAt       DateTime?
  activationCode    String?
  withdrawalStatus  String   @default("allowed") // allowed | pending | hold | suspended | restricted
  withdrawalMessage String?
  controls          Json? // per-user capability toggles (design spec §9.3 / user controls)
  transferCodes     Json? // { imf: string[], tax: string[], cot: string[] }

  // Referrals (self relation)
  referredById String?
  referredBy   User?   @relation("Referrals", fields: [referredById], references: [id])
  referrals    User[]  @relation("Referrals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions      Session[]
  accounts      Account[]
  wallets       Wallet[]
  transactions  WalletTransaction[]
  notifications Notification[]

  @@index([status])
  @@index([kycStatus])
  @@index([createdAt])
  @@map("user")
}

model Session {
  id             String   @id
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  password              String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ---------------------------------------------------------------------------
// Wallet & ledger. Balance is a cache of the append-only ledger; currency
// integrity is enforced by the composite FK on wallet_transactions.
// ---------------------------------------------------------------------------

model Wallet {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency     String
  balanceMinor BigInt   @default(0) @map("balance_minor")
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  transactions WalletTransaction[]

  @@unique([userId, currency])
  @@unique([id, currency]) // backs the composite FK below
  @@index([userId])
  @@map("wallets")
}

model WalletTransaction {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletId          String   @map("wallet_id")
  currency          String
  wallet            Wallet   @relation(fields: [walletId, currency], references: [id, currency], onDelete: Cascade)
  direction         String // credit | debit
  amountMinor       BigInt   @map("amount_minor")
  source            String // deposit | withdrawal | withdrawal_reversal | adjustment | fee | transfer | rebate | reward
  referenceType     String?  @map("reference_type")
  referenceId       String?  @map("reference_id")
  idempotencyKey    String   @unique @map("idempotency_key")
  balanceAfterMinor BigInt   @map("balance_after_minor")
  status            String   @default("completed") // completed | pending | failed
  provider          String?
  description       String?
  memo              String?
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([walletId])
  @@map("wallet_transactions")
}

// ---------------------------------------------------------------------------
// App support models
// ---------------------------------------------------------------------------

model Notification {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // email | push
  title       String?
  message     String
  scheduledAt DateTime?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@map("notifications")
}

model ActivationCode {
  id        String    @id @default(uuid())
  code      String    @unique
  createdBy String?
  usedById  String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("activation_codes")
}

/// Feature flags toggled from the admin panel. Fail closed when a key is missing.
model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  description String?
  updatedBy   String?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}
