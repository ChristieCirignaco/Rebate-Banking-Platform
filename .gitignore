# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — real values never get committed. The .example is the TEMPLATE and must be,
# otherwise a deploy has no record of which vars to set; it holds placeholders only.
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code local runtime
.claude/
# throwaway merge/build test worktrees
/.mergetest*

# local object storage (uploaded files; served via access-controlled route)
/storage
